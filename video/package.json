{
  "name": "redibat-video",
  "version": "1.0.0",
  "private": true,
  "description": "Vidéo de présentation Rédibat — motion design Remotion (texte + musique + bruitages, sans voix)",
  "scripts": {
    "studio": "remotion studio",
    "audio": "node scripts/generate-audio.mjs",
    "render": "remotion render RedibatPresentation out/redibat-presentation.mp4",
    "render:square": "remotion render RedibatSquare out/redibat-presentation-1x1.mp4"
  },
  "dependencies": {
    "@remotion/cli": "4.0.246",
    "@remotion/google-fonts": "4.0.246",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.246"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  }
}
